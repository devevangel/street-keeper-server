{
  "name": "backend",
  "version": "1.0.0",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "dev": "npm run dev:local",
    "dev:local": "cross-env DOTENV_CONFIG_PATH=.env nodemon",
    "dev:remote": "cross-env DOTENV_CONFIG_PATH=.env.remote nodemon",
    "dev:prod": "npm run dev:remote",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:migrate:reset": "cross-env DOTENV_CONFIG_PATH=.env npx prisma migrate reset --force",
    "db:reset:local": "npm run db:migrate:reset",
    "db:reset:remote": "cross-env DOTENV_CONFIG_PATH=.env.remote npx prisma migrate reset --force",
    "build": "npx prisma generate && npx prisma migrate deploy && (tsc || true)",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "backfill:street-progress": "tsx src/scripts/backfill-user-street-progress.ts",
    "cleanup:low-coverage": "tsx src/scripts/cleanup-low-coverage-street-progress.ts",
    "cleanup:unnamed": "tsx src/scripts/cleanup-unnamed-street-progress.ts",
    "reset:processed-activities": "tsx src/scripts/reset-processed-activities.ts",
    "recalculate:project-progress": "tsx src/scripts/recalculate-project-progress.ts",
    "reset:all-progress": "tsx src/scripts/reset-all-progress.ts",
    "reset:everything": "tsx src/scripts/reset-all-progress-complete.ts",
    "seed:way-cache": "tsx src/scripts/seed-way-cache-from-pbf.ts",
    "wipe:and-resync": "tsx src/scripts/wipe-and-resync.ts",
    "seed:demo-project": "tsx src/scripts/seed-demo-project.ts",
    "clear:app-data": "tsx src/scripts/clear-app-data.ts",
    "recompute:project-progress": "tsx src/scripts/recompute-project-progress.ts",
    "delete:archived-project-data": "tsx src/scripts/delete-archived-project-data.ts",
    "delete:all-projects": "tsx src/scripts/delete-all-projects.ts",
    "db:size": "tsx src/scripts/db-size.ts",
    "db:reset": "cross-env DOTENV_CONFIG_PATH=.env tsx src/scripts/reset-database.ts",
    "sync:city": "tsx src/scripts/sync-city.ts",
    "webhook:register": "tsx src/scripts/register-webhook.ts",
    "reset:user-data": "tsx src/scripts/reset-user-data.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.2.0",
    "@prisma/client": "^7.2.0",
    "@tmcw/togeojson": "^7.1.2",
    "@turf/turf": "^7.3.2",
    "@types/geojson": "^7946.0.16",
    "@xmldom/xmldom": "^0.8.11",
    "axios": "^1.13.2",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "marked": "^17.0.1",
    "multer": "^2.0.2",
    "pg": "^8.17.1",
    "pg-boss": "^12.5.4",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "tiny-osmpbf": "^1.0.0-beta.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.0.0",
    "@types/node": "^25.0.9",
    "@types/pg": "^8.16.0",
    "@types/supertest": "^6.0.3",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.2",
    "nodemon": "^3.1.11",
    "prisma": "^7.2.0",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.53.0",
    "vitest": "^4.0.17"
  }
}
