NODE_ENV=development
PORT=8000

# Copy this file to `.env` for local development (`npm run dev` / `npm run dev:local`).
# Local PostgreSQL with PostGIS. Optional DB via Docker from backend/: `npm run db:up`
# Then: npx prisma migrate deploy
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/streetkeeper"

# Hosted DB (Supabase, etc.): copy `.env.remote.example` to `.env.remote` and use:
#   npm run dev:remote
#
# Wipe all data using this file’s DATABASE_URL (truncate — fast, keeps schema):
#   npm run db:reset
# Full Prisma reset (drop + migrate from scratch):
#   npm run db:migrate:reset

STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_REDIRECT_URI=http://localhost:8000/api/v1/auth/strava/callback

# Optional
# FRONTEND_URL=http://localhost:5173
# MAPBOX_ACCESS_TOKEN=
# GPX_ENGINE_VERSION=v2
# SKIP_OVERPASS=true
