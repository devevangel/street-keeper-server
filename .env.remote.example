# Copy to .env.remote (gitignored) and fill DATABASE_URL when you want `npm run dev:remote`
# (hosted Supabase / staging — not your laptop Postgres).

NODE_ENV=development
PORT=8000

DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_REDIRECT_URI=http://localhost:8000/api/v1/auth/strava/callback

# Prisma CLI does not use dev:remote; for migrations against this DB run, from backend/:
#   cross-env DOTENV_CONFIG_PATH=.env.remote npx prisma migrate deploy
