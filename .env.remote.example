# Copy to .env.remote (gitignored) and fill DATABASE_URL when you want `npm run dev:remote`
# (hosted Supabase / staging — not your laptop Postgres).

NODE_ENV=development
PORT=8000

# Supabase → Project Settings → Database → URI (use "Direct connection" for prisma migrate)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_REDIRECT_URI=http://localhost:8000/api/v1/auth/strava/callback

# Hard reset remote DB (drops all data, reapplies migrations):
#   npm run db:reset:remote
#
# Migrations only (no wipe):
#   cross-env DOTENV_CONFIG_PATH=.env.remote npx prisma migrate deploy
